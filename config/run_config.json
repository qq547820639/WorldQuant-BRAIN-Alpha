{
  "schema_version": "v2.0",
  "environment": "production",
  "auto_submit": false,
  "credentials": {
    "username": "",
    "password": "",
    "token": "",
    "username_env": "BRAIN_USERNAME",
    "password_env": "BRAIN_PASSWORD",
    "token_env": "BRAIN_TOKEN"
  },
  "web": {
    "host": "127.0.0.1",
    "port": 8765,
    "open_browser": true,
    "session_ttl_seconds": 43200,
    "allow_multiple_sessions": true,
    "allow_remote": false
  },
  "ops": {
    "storage_dir": "data",
    "source_tag_policy": "official/experience/inference/manual",
    "settings": {
      "instrumentType": "EQUITY",
      "region": "USA",
      "universe": "TOP3000",
      "delay": 1,
      "dataset": "",
      "decay": 10,
      "neutralization": "SUBINDUSTRY",
      "truncation": 0.05,
      "pasteurization": "ON",
      "unitHandling": "VERIFY",
      "nanHandling": "ON",
      "language": "FASTEXPR",
      "visualization": false,
      "type": "REGULAR"
    },
    "budget": {
      "max_candidates_per_cycle": 20,
      "max_official_validations_per_cycle": 10,
      "max_official_simulations_per_cycle": 3,
      "max_official_concurrent_simulations": 3,
      "retained_alpha_pool_size": 10,
      "official_backtest_batch_size": 3,
      "min_local_quality_score": 4.0,
      "min_prior_score_for_official_validation": 60.0,
      "min_prior_score_for_official_simulation": 70.0,
      "stop_official_calls_on_rate_limit": false,
      "run_forever": true,
      "cycle_pause_seconds": 2.0,
      "official_retry_pause_seconds": 6.0,
      "adaptive_strategy_enabled": true,
      "adaptive_min_official_results": 12,
      "adaptive_min_cycles": 20,
      "adaptive_min_ready_rate": 0.05,
      "require_cloud_sync": false,
      "cloud_sync_range": "3d",
      "max_cycles": 0,
      "dataset_strategy": "rotate",
      "generation_mode_ratio": "70/20/10",
      "hypothesis_library_dir": "brain_alpha_ops/research/hypotheses",
      "use_assistant_guidance": true,
      "assistant_guidance_min_confidence": 0.6
    },
    "scoring": {
      "assistant_guidance_score_adjustment_enabled": true,
      "assistant_guidance_score_min_confidence": 0.6,
      "assistant_guidance_score_min_outcome_count": 1,
      "assistant_guidance_score_bonus_cap": 4.0,
      "assistant_guidance_score_penalty_cap": 5.0
    },
    "thresholds": {
      "min_sharpe": 1.25,
      "min_sharpe_delay0": 2.0,
      "min_fitness": 1.0,
      "min_fitness_delay0": 1.3,
      "min_turnover": 0.01,
      "platform_max_turnover": 0.70,
      "target_max_turnover": 0.30,
      "enforce_target_turnover_as_hard_gate": false,
      "min_returns": 0.0,
      "max_drawdown": 0.25,
      "max_self_correlation": 0.70,
      "max_prod_correlation": 0.70,
      "max_weight_concentration": 0.10,
      "sub_universe_sharpe_min_ratio": 0.75,
      "require_official_pass": true,
      "require_official_metrics": true,
      "require_data_compliance": true,
      "require_economic_logic": true
    },
    "submission_policy": {
      "max_auto_submissions_per_day": 3,
      "max_auto_submissions_per_run": 2,
      "min_minutes_between_auto_submissions": 120,
      "max_expression_similarity": 0.9,
      "block_micro_variants": true,
      "require_pre_submit_check_passed": true
    },
    "official_api": {
      "base_url": "https://api.worldquantbrain.com",
      "authentication_path": "/authentication",
      "simulations_path": "/simulations",
      "data_fields_path": "/data-fields",
      "operators_path": "/operators",
      "alpha_path_template": "/alphas/{alpha_id}",
      "user_alphas_path": "/users/self/alphas",
      "alpha_check_path_template": "/alphas/{alpha_id}/check",
      "alpha_submit_path_template": "/alphas/{alpha_id}/submit",
      "timeout_seconds": 60,
      "poll_attempts": 120,
      "poll_interval_seconds": 6.0,
      "min_request_interval_seconds": 3.0,
      "rate_limit_retry_attempts": 3,
      "rate_limit_backoff_seconds": 15.0,
      "cache_dir": "data/api_cache",
      "context_cache_ttl_seconds": 86400,
      "allow_stale_context_on_rate_limit": true
    }
  }
}
